{
  "kind": "collectionType",
  "collectionName": "menu_categories",
  "info": {
    "singularName": "menu-category",
    "pluralName": "menu-categories",
    "displayName": "Menu Category"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "component",
      "repeatable": false,
      "component": "shared.localized-string",
      "required": true
    },
    "name": {
      "type": "component",
      "repeatable": false,
      "component": "shared.localized-string",
      "required": true
    },
    "description": {
      "type": "component",
      "repeatable": false,
      "component": "shared.localized-text"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo-metadata"
    }
  }
}
